{
  "manifest_version": 3,
  "name": "Movier",
  "version": "1.3.1",
  "description": "Плееры на Кинопоиске: смотрите фильмы и сериалы прямо на странице и без лишней рекламы в плеерах.",
  "homepage_url": "https://kurduk.store/",
  "icons": {
    "16": "16.png",
    "48": "48.png",
    "128": "128.png"
  },
  "action": {
    "default_title": "Movier",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "16.png",
      "48": "48.png",
      "128": "128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.kinopoisk.ru/film/*",
        "https://www.kinopoisk.ru/series/*"
      ],
      "run_at": "document_idle",
      "css": ["css/main.css"],
      "js": ["content/kinopoisk.js"]
    },
    {
      "matches": ["https://hd.kinopoisk.ru/*"],
      "run_at": "document_idle",
      "css": ["css/main.css"],
      "js": ["content/hd-redirect.js"]
    }
  ],
  "permissions": ["storage", "alarms", "declarativeNetRequest", "scripting"],
  "host_permissions": [
    "https://kp.apiget.ru/*",
    "https://kurduk.store/*",
    "https://rthell.github.io/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "movier_ads",
        "enabled": true,
        "path": "rules/adblock.json"
      }
    ]
  }
}
