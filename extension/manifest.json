{
    "manifest_version": 3,
    "name": "Movier",
    "version": "1.2.0",
    "description": "Плееры на Кинопоиске и блокировка рекламы в плеерах.",
    "icons": {
        "16": "16.png",
        "128": "logo.png"
    },
    "background": {
        "service_worker": "background_process.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.kinopoisk.ru/film/*",
                "https://www.kinopoisk.ru/series/*"
            ],
            "run_at": "document_start",
            "css": ["./css/main.css"],
            "js": ["config.js", "jquery.js", "background.js"]
        },
        {
            "matches": ["https://hd.kinopoisk.ru/*"],
            "run_at": "document_start",
            "css": ["./css/main.css"],
            "js": ["config.js", "jquery.js", "backToOrigKP.js"]
        },
        {
            "matches": ["http://*/*", "https://*/*"],
            "run_at": "document_start",
            "all_frames": true,
            "match_about_blank": true,
            "js": ["adblock-frame.js"]
        }
    ],
    "permissions": [
        "storage",
        "alarms",
        "declarativeNetRequest"
    ],
    "host_permissions": [
        "https://*/*",
        "http://*/*"
    ],
    "declarative_net_request": {
        "rule_resources": [
            {
                "id": "movier_ads",
                "enabled": true,
                "path": "rules/adblock.json"
            }
        ]
    }
}
