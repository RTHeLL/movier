{
  "name": "movier",
  "private": true,
  "version": "1.3.0",
  "scripts": {
    "dev:server": "npm run dev --prefix server",
    "dev:web": "npm run dev --prefix web",
    "build:server": "npm run build --prefix server",
    "build:web": "npm run build --prefix web",
    "build": "npm run build:server && npm run build:web",
    "validate:extension": "node scripts/validate-extension.js",
    "pack:extension": "node scripts/pack-extension.js",
    "build:extension": "npm run pack:extension",
    "release:check": "npm run validate:extension && npm run build:server && npm run build:web && npm run pack:extension"
  }
}
